#!/system/bin/sh
# PRoot wrapper — uses Termux's proot if installed.
# For a standalone build, replace this file with a statically-compiled
# ARM64 proot binary (see https://github.com/proot/proot).
#
# To build from source:
#   git clone https://github.com/proot/proot.git
#   cd proot && make -C src proot
#   # Cross-compile for aarch64 with NDK

TERMUX_PROOT="/data/data/com.termux/files/usr/bin/proot"

if [ -x "$TERMUX_PROOT" ]; then
    exec "$TERMUX_PROOT" "$@"
else
    echo "ERROR: PRoot binary not found." >&2
    echo "Install Termux from F-Droid, then run: pkg install proot" >&2
    exit 1
fi
